# .env.example — copy to `.env` and edit. docker-compose auto-loads `.env`.
# These are the design knobs for a wafer.space gf180mcuD shuttle. The defaults
# below are a known-good starting point; you usually only change SLOT.

# Physical area on the shuttle reticle. One of: 1x1  0p5x1  1x0p5  0p5x0p5
SLOT=1x0p5

# Process design kit family (the foundry's rulebook + cell libraries).
PDK=gf180mcuD

# Standard-cell library. fd_sc_mcu7t5v0 is the default 5V 7-track library.
SCL=gf180mcu_fd_sc_mcu7t5v0

# I/O pad ring library.
PAD=gf180mcu_fd_io

# SRAM macro library (only used if your design instantiates SRAM).
SRAM=gf180mcu_fd_ip_sram

# Path A only: override the official LibreLane image tag if the default is wrong.
# See docker/Dockerfile.harden's <VERIFY> note for how to confirm the tag.
# LIBRELANE_IMAGE=ghcr.io/librelane/librelane:latest
